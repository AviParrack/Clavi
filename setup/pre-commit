#!/bin/bash
# Pre-commit hook: scan staged files for secrets using detect-secrets
# Install: cp setup/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

if command -v detect-secrets &> /dev/null; then
    git diff --cached --name-only | xargs detect-secrets scan --list 2>/dev/null
    if [ $? -ne 0 ]; then
        echo ""
        echo "⚠️  detect-secrets found potential secrets in staged files."
        echo "    Review the findings above and either:"
        echo "    1. Remove the secrets from the files"
        echo "    2. Add them to .secrets.baseline if they're false positives"
        echo ""
        exit 1
    fi
else
    echo "⚠️  detect-secrets not installed. Run: pip3 install detect-secrets"
    echo "   Skipping secret scan..."
fi
